# Public site URL — used for canonical, sitemap, robots, OG metadata.
# Set this to your real domain in production.
NEXT_PUBLIC_SITE_URL=https://pdf.home.gustavorh.com

# Optional privacy-first analytics. Leave blank to fully disable.
# To enable, deploy a self-hosted Plausible instance and set both values.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=ceropdf.example.com
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.example.com/js/script.js

# Optional heavy-jobs sidecar (internal). Only required for tools that need
# server-side processing (e.g., real compression, Office→PDF via LibreOffice).
# Should point to the internal Docker network address of the
# heavy service. Without it, those tools return 503 and degrade gracefully.
# HEAVY_API_URL=http://heavy:3001
